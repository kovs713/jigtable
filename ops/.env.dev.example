JIGTABLE_ENV_FILE=.env.dev
SERVER_IMAGE=ghcr.io/<owner>/<repo>/server:<tag>

POSTGRES_USER=postgres
POSTGRES_PASSWORD=<dev-db-password>
POSTGRES_DB=jigtable_dev

DB_URL=postgresql://postgres:<dev-db-password>@postgres:5432/jigtable_dev
PORT=3000
CLIENT_URL=https://jigtable.ru
PUBLIC_API_URL=https://api.jigtable.ru
CORS_ORIGIN=https://jigtable.ru,https://www.jigtable.ru

BOT_TOKEN=<telegram-bot-token>
ADMIN_USER_ID=<telegram-admin-user-id>
TELEGRAM_PROXY_URL=http://xray:10809
XRAY_CONFIG_FILE=./xray/config.json

S3_ENDPOINT=<s3-endpoint>
S3_REGION=<s3-region>
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=<s3-access-key-id>
S3_SECRET_ACCESS_KEY=<s3-secret-access-key>
S3_BUCKET=<s3-bucket>
