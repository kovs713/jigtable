PORT=3000
CLIENT_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=DEV

BOT_TOKEN=<TELEGRAM BOT TOKEN>
ADMIN_USER_ID=<TELEGRAM ADMIN USER ID>
TELEGRAM_PROXY_URL=

S3_ENDPOINT=<S3 ENDPOINT>
S3_REGION=<S3 REGION>
S3_FORCE_PATH_STYLE=true
S3_TENANT_ID=<S3 TENANT ID>
S3_KEY_ID=<S3 KEY ID>
S3_ACCESS_KEY_ID=$S3_TENANT_ID:$S3_KEY_ID
S3_SECRET_ACCESS_KEY=<key_secret>
S3_BUCKET=jigtable-media
S3_PUBLIC_URL=<S3 PUBLIC MEDIA URL>

DB_USERNAME=postgres
DB_PASSWORD=<DB PASSWORD>
DB_DATABASE=db
DB_PORT=5432
DB_URL=postgresql://$DB_USERNAME:$DB_PASSWORD@127.0.0.1:$DB_PORT/$DB_DATABASE

REDIS_PASSWORD=<REDIS PASSWORD>
REDIS_PORT=6379
REDIS_URL=redis://:$REDIS_PASSWORD@127.0.0.1:$REDIS_PORT
