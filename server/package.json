{
  "name": "server",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run native:build && bun --watch src/main.ts",
    "start": "bun run native:build && bun src/main.ts",
    "native:build": "bun run scripts/build-shuffle-native.ts --release",
    "native:check": "cargo check --manifest-path native/shuffle/Cargo.toml",
    "db:push": "bunx --bun drizzle-kit push",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test:shuffle": "bun run native:build && bun test src/shuffle/index.test.ts"
  },
  "dependencies": {
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/storage-psql": "^2.5.1",
    "@jigtable/jigsaw-core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "pg": "^8.22.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
