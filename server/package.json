{
  "name": "server",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run native:build && bun --watch src/main.ts",
    "start": "bun run native:build && bun src/main.ts",
    "native:build": "bun run scripts/build-collage-layout-engine-native.ts --release",
    "native:check": "cargo check --manifest-path native/collage-layout-engine/Cargo.toml",
    "db:push": "bunx --bun drizzle-kit push",
    "db:generate": "bunx --bun drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bunx --bun drizzle-kit migrate --config=drizzle.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "bunx tsc --noEmit",
    "test:collage-layout-engine": "bun run native:build && bun test src/collage-layout-engine/index.test.ts"
  },
  "dependencies": {
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/storage-psql": "^2.5.1",
    "@jigtable/jigsaw-core": "workspace:*",
    "@jigtable/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "pg": "^8.22.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
